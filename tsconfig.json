{
  "compilerOptions": {
    "paths": { "*": ["./*"] },
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2018",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "lib": ["DOM", "ES2018"],
    "types": ["@wdio/globals/types", "@wdio/mocha-framework", "wdio-obsidian-service"]
  },
  "include": ["**/*.ts"],
  "exclude": ["tests/**"]
}
