{
  "name": "fancy-kanban",
  "version": "0.1.4",
  "description": "Embeddable kanban boards in any note, with native swimlanes and a relational field model.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "wdio run ./wdio.conf.mts"
  },
  "keywords": [],
  "author": "Roberto Allende",
  "license": "MIT",
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@wdio/cli": "^9.29.1",
    "@wdio/globals": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "esbuild": "0.21.5",
    "jsdom": "^29.1.1",
    "mocha": "^11.7.6",
    "obsidian": "latest",
    "tslib": "2.6.0",
    "typescript": "^7.0.0",
    "vitest": "^4.1.10",
    "wdio-obsidian-reporter": "^3.1.1",
    "wdio-obsidian-service": "^3.1.1"
  }
}
